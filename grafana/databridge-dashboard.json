{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" }
  ],
  "id": null,
  "uid": "databridge-overview",
  "title": "databridge Overview",
  "description": "API, worker, and export pipeline observability for databridge",
  "tags": ["databridge", "prometheus"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "api_instance",
        "label": "API Instance",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(up{job=\"databridge\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "worker_instance",
        "label": "Worker Instance",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(up{job=\"databridge-worker\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(http_requests_total{job=\"databridge\", instance=~\"$api_instance\"}, endpoint)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "sink_type",
        "label": "Sink Type",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(export_jobs_completed_total{job=\"databridge-worker\", instance=~\"$worker_instance\"}, sink_type)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "API Request Rate",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"databridge\", instance=~\"$api_instance\"}[$__rate_interval]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "API 5xx Rate",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"databridge\", instance=~\"$api_instance\", status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "API P95 Latency",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"databridge\", instance=~\"$api_instance\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Export Failures/s",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(export_jobs_failed_total{job=\"databridge-worker\", instance=~\"$worker_instance\", sink_type=~\"$sink_type\"}[$__rate_interval]))",
          "legendFormat": "failures/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Requests/s by Endpoint",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"databridge\", instance=~\"$api_instance\", endpoint=~\"$endpoint\"}[$__rate_interval])) by (endpoint)",
          "legendFormat": "{{ endpoint }}"
        }
      ]
    },
    {
      "id": 8,
      "title": "HTTP Latency P50 / P95 / P99",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 1, "fillOpacity": 5 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"databridge\", instance=~\"$api_instance\", endpoint=~\"$endpoint\"}[$__rate_interval])) by (le, endpoint))",
          "legendFormat": "p50 {{ endpoint }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"databridge\", instance=~\"$api_instance\", endpoint=~\"$endpoint\"}[$__rate_interval])) by (le, endpoint))",
          "legendFormat": "p95 {{ endpoint }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"databridge\", instance=~\"$api_instance\", endpoint=~\"$endpoint\"}[$__rate_interval])) by (le, endpoint))",
          "legendFormat": "p99 {{ endpoint }}"
        }
      ]
    },
    {
      "id": 9,
      "title": "HTTP Status Rate",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"databridge\", instance=~\"$api_instance\", endpoint=~\"$endpoint\"}[$__rate_interval])) by (status_code)",
          "legendFormat": "{{ status_code }}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Preview and PII Detection Latency P95",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 1, "fillOpacity": 5 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(preview_request_duration_seconds_bucket{job=\"databridge\", instance=~\"$api_instance\"}[$__rate_interval])) by (le, connection_type))",
          "legendFormat": "preview p95 {{ connection_type }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(pii_fields_request_duration_seconds_bucket{job=\"databridge\", instance=~\"$api_instance\"}[$__rate_interval])) by (le, connection_type))",
          "legendFormat": "pii p95 {{ connection_type }}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Export Pipeline",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "title": "Export Job Lifecycle/s",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum(rate(export_jobs_created_total{job=\"databridge\", instance=~\"$api_instance\", sink_type=~\"$sink_type\"}[$__rate_interval])) by (sink_type)",
          "legendFormat": "created {{ sink_type }}"
        },
        {
          "expr": "sum(rate(export_jobs_completed_total{job=\"databridge-worker\", instance=~\"$worker_instance\", sink_type=~\"$sink_type\"}[$__rate_interval])) by (sink_type)",
          "legendFormat": "completed {{ sink_type }}"
        },
        {
          "expr": "sum(rate(export_jobs_failed_total{job=\"databridge-worker\", instance=~\"$worker_instance\", sink_type=~\"$sink_type\"}[$__rate_interval])) by (sink_type)",
          "legendFormat": "failed {{ sink_type }}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Active Export Jobs by Org",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 15 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(export_active_jobs{job=\"databridge-worker\", instance=~\"$worker_instance\"}) by (org_id)",
          "legendFormat": "{{ org_id }}"
        }
      ]
    },
    {
      "id": 14,
      "title": "Export Throughput by Sink",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(export_records_per_second{job=\"databridge-worker\", instance=~\"$worker_instance\", sink_type=~\"$sink_type\"}) by (sink_type)",
          "legendFormat": "{{ sink_type }}"
        }
      ]
    },
    {
      "id": 15,
      "title": "Asset Resolution Results/s",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum(rate(export_asset_resolution_success_total{job=\"databridge-worker\", instance=~\"$worker_instance\"}[$__rate_interval]))",
          "legendFormat": "success"
        },
        {
          "expr": "sum(rate(export_asset_resolution_failed_total{job=\"databridge-worker\", instance=~\"$worker_instance\"}[$__rate_interval]))",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 16,
      "title": "Transform and Webhook Activity",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum(rate(masking_rules_applied_total{job=\"databridge-worker\", instance=~\"$worker_instance\"}[$__rate_interval])) by (org_id)",
          "legendFormat": "masked {{ org_id }}"
        },
        {
          "expr": "sum(rate(sampling_records_dropped_total{job=\"databridge-worker\", instance=~\"$worker_instance\"}[$__rate_interval])) by (org_id)",
          "legendFormat": "sampled out {{ org_id }}"
        },
        {
          "expr": "sum(rate(webhook_delivery_total{job=\"databridge-worker\", instance=~\"$worker_instance\"}[$__rate_interval])) by (status)",
          "legendFormat": "webhook {{ status }}"
        }
      ]
    },
    {
      "id": 17,
      "title": "Process Memory",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 1, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"databridge\", instance=~\"$api_instance\"}",
          "legendFormat": "api {{ instance }}"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"databridge-worker\", instance=~\"$worker_instance\"}",
          "legendFormat": "worker {{ instance }}"
        }
      ]
    },
    {
      "id": 18,
      "title": "Scrape Health",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 46 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "max": 1, "custom": { "lineWidth": 1, "fillOpacity": 20 } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "up{job=~\"databridge|databridge-worker\"}",
          "legendFormat": "{{ job }} {{ instance }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
